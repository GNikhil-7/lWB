# =============================================================================
# Leon & Walker — Backend Environment Variables
# Copy this file to .env for local development (NEVER commit .env)
# Set these as environment variables in Railway / Vercel dashboard for production
# =============================================================================

# ---------------------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(50))"

DJANGO_DEBUG=false

# ---------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ---------------------------------------------------------------------------
# For LOCAL development — use the direct host:
# DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# For Railway / Vercel — MUST use the Session Pooler (avoids IPv6 issues):
DATABASE_URL=postgresql://postgres.your-project-ref:your-url-encoded-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Connection settings
# Set to 0 when using Supabase pooler (pooler manages connections itself)
DB_CONN_MAX_AGE=0
DB_SSL_REQUIRE=true

# ---------------------------------------------------------------------------
# Hosts & CORS (comma-separated, no trailing slashes on origins)
# ---------------------------------------------------------------------------
# Add your Railway domain here (Railway sets RAILWAY_PUBLIC_DOMAIN automatically)
DJANGO_ALLOWED_HOSTS=your-app.up.railway.app

DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ---------------------------------------------------------------------------
# Cookies (leave false unless running HTTPS outside Railway/Vercel)
# ---------------------------------------------------------------------------
FORCE_SECURE_COOKIES=false
