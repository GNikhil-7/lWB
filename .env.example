DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
# Local/direct example:
# DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
#
# Vercel/serverless example:
# DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres
#
# Get the exact pooler string from Supabase Dashboard > Connect.
# Do not paste markdown links, brackets, or mailto-formatted text here.
DATABASE_URL=postgresql://postgres.your-project-ref:replace-with-url-encoded-password@aws-0-your-region.pooler.supabase.com:5432/postgres
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=true
DJANGO_ALLOWED_HOSTS=lw-project.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://lw-project.vercel.app,https://lw-project-jy9r.vercel.app
CORS_ALLOWED_ORIGINS=https://lw-project-jy9r.vercel.app
# Local development keeps cookies non-secure automatically.
# Set this only when running behind HTTPS outside Vercel.
FORCE_SECURE_COOKIES=false
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
